            "description": "OK"
          }
        }
      }
    },
    "/api/admin/restaurants/{restaurantId}/menu/import": {
      "post": {
        "tags": [
          "Admin Catalog"
        ],
        "summary": "Bulk-import a restaurant menu from Excel + images zip",
        "parameters": [
          {
            "name": "restaurantId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "menu"
                ],
                "type": "object",
                "properties": {
                  "menu": {
                    "type": "string",
                    "format": "binary"
                  },
                  "images": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "menu": {
                  "style": "form"
                },
                "images": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
